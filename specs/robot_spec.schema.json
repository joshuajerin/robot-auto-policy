{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robogenesis.local/specs/robot_spec.schema.json",
  "title": "RobotSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["robot_id", "embodiment_type", "asset_path", "num_dofs", "controlled_joints"],
  "properties": {
    "robot_id": {"type": "string", "minLength": 1},
    "embodiment_type": {"type": "string", "minLength": 1},
    "asset_path": {"type": "string", "minLength": 1},
    "num_dofs": {"type": "integer", "minimum": 1},
    "controlled_joints": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "actuator_groups": {
      "type": "object",
      "additionalProperties": {"type": "array", "items": {"type": "string"}}
    },
    "limits": {"type": "object"}
  }
}
