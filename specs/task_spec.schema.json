{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://robogenesis.local/specs/task_spec.schema.json",
  "title": "TaskSpec",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "task_family", "objective", "base_env"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "task_family": {
      "type": "string",
      "enum": ["locomotion", "manipulation", "navigation", "aerial", "locomanipulation"]
    },
    "objective": {"type": "string", "minLength": 1},
    "base_env": {"type": "string", "minLength": 1},
    "commands": {"type": "object"},
    "style_targets": {"type": "object"}
  }
}
